{
  // See https://go.microsoft.com/fwlink/?LinkId=733558
  // for the documentation about the tasks.json format
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Serve",
      "type": "shell",
      "command": "make serve",
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "isBackground": true,
      "problemMatcher": [
        "$jekyll-error-watch",
        "$jekyll-warning-watch"
      ]
    },
    {
      "label": "Build",
      "type": "shell",
      "command": "make build",
      "problemMatcher": [
        "$jekyll-error",
        "$jekyll-warning"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Drafts",
      "type": "shell",
      "command": "make serve-drafts",
      "group": "test",
      "isBackground": true,
      "problemMatcher": [
        "$jekyll-error-watch",
        "$jekyll-warning-watch"
      ]
    }
  ]
}
